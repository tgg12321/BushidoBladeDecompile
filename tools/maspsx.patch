+    # Load external .sdata symbol list if provided
+    sdata_sym_list = []
+    if args.sdata_syms:
+        with open(args.sdata_syms, "r", encoding="utf") as f:
+            sdata_sym_list = [line.strip() for line in f if line.strip() and not line.startswith("#")]
